Subject: [PATCH] UI: hidden hudText when ResetEvent

---
 core/src/mindustry/ui/fragments/HudFragment.java | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/core/src/mindustry/ui/fragments/HudFragment.java b/core/src/mindustry/ui/fragments/HudFragment.java
index c121c725a0c3ce485a0ac687834bbcfdfc29d23b..5a3093ff12f1ae95633e06933b9ae5ef34d11d43 100644
--- a/core/src/mindustry/ui/fragments/HudFragment.java
+++ b/core/src/mindustry/ui/fragments/HudFragment.java
@@ -674,6 +674,12 @@ public class HudFragment{
                 .with(p -> p.visible(() -> (p.color.a = Mathf.lerpDelta(p.color.a, Mathf.num(showHudText), 0.2f)) >= 0.001f));
         });
 
+        //MDTX: hidden when change map
+        Events.on(EventType.ResetEvent.class, e -> {
+            hudText = "";
+            showHudText = false;
+        });
+
         //spawner warning
         parent.fill(t -> {
             t.name = "nearpoint";
