diff --git a/core/src/mindustry/net/Net.java b/core/src/mindustry/net/Net.java
index 53aea8b5fd627dda0c592eede372091a13814eb1..f1778c69977d407103ee3f741d47f6a569b17d70 100644
--- a/core/src/mindustry/net/Net.java
+++ b/core/src/mindustry/net/Net.java
@@ -10,6 +10,7 @@ import mindustry.game.EventType.*;
 import mindustry.gen.*;
 import mindustry.net.Packets.*;
 import mindustry.net.Streamable.*;
+import mindustryX.events.*;
 import net.jpountz.lz4.*;
 
 import java.io.*;
@@ -242,6 +243,7 @@ public class Net{
 
     /** Send an object to all connected clients, or to the server if this is a client.*/
     public void send(Object object, boolean reliable){
+        if(SendPacketEvent.emit(null, null, object)) return;
         if(server){
             provider.sendAllServer(object, reliable);
         }else{
@@ -256,6 +258,7 @@ public class Net{
 
     /** Send an object to everyone EXCEPT a certain client. Server-side only.*/
     public void sendExcept(NetConnection except, Object object, boolean reliable){
+        if(SendPacketEvent.emit(null, except, object)) return;
         provider.sendExceptServer(except, object, reliable);
     }
 
@@ -416,6 +419,7 @@ public class Net{
         /** Sends a packet to a specific list of clients. */
         default void sendAllServer(Object object, Iterable<NetConnection> connections, boolean reliable){
             for(NetConnection con : connections){
+                if(!con.hasBegunConnecting) continue;
                 con.send(object, reliable);
             }
         }
@@ -430,7 +434,7 @@ public class Net{
         /** Sends a packet to all connected clients, except the specified one. */
         default void sendExceptServer(NetConnection except, Object object, boolean reliable){
             for(NetConnection con : getConnections()){
-                if(con != except){
+                if(con != except && con.hasBegunConnecting){
                     con.send(object, reliable);
                 }
             }
