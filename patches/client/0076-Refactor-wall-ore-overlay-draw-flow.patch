From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Wind-DeterMination-backup
 <Wind-DeterMination-backup@users.noreply.github.com>
Date: Sun, 15 Mar 2026 12:07:06 +0800
Subject: [PATCH] Refactor wall ore overlay draw flow

---
 .../world/blocks/environment/Cliff.java       | 18 +++---
 .../world/blocks/environment/StaticTree.java  | 62 +++++++++----------
 2 files changed, 38 insertions(+), 42 deletions(-)

diff --git a/core/src/mindustry/world/blocks/environment/Cliff.java b/core/src/mindustry/world/blocks/environment/Cliff.java
index 89119b53d5873ea3d6ff083d9aabc2456d0ef69c..5b855a21d8ddaff7bab5927c7ca405e8d9bf113a 100644
--- a/core/src/mindustry/world/blocks/environment/Cliff.java
+++ b/core/src/mindustry/world/blocks/environment/Cliff.java
@@ -26,18 +26,16 @@ public class Cliff extends Block{
 
     @Override
     public void drawBase(Tile tile){
-        if(!RenderExt.shouldDrawBuildingBase()){
-            if(RenderExt.shouldDrawOreLayer() && tile.overlay().wallOre){
-                tile.overlay().drawBase(tile);
-            }
-            return;
-        }
+        boolean renderBlock = RenderExt.shouldDrawBuildingBase();
+        boolean renderOre = tile.overlay().wallOre && RenderExt.shouldDraw(tile.overlay());
 
-        Draw.color(Tmp.c1.set(tile.floor().mapColor).mul(1.6f));
-        Draw.rect(tile.data != 0 ? cliffs[tile.data & 0xff] : region, tile.worldx(), tile.worldy());
-        Draw.color();
+        if(renderBlock){
+            Draw.color(Tmp.c1.set(tile.floor().mapColor).mul(1.6f));
+            Draw.rect(tile.data != 0 ? cliffs[tile.data & 0xff] : region, tile.worldx(), tile.worldy());
+            Draw.color();
+        }
 
-        if(RenderExt.shouldDrawOreLayer() && tile.overlay().wallOre){
+        if(renderOre){
             tile.overlay().drawBase(tile);
         }
     }
diff --git a/core/src/mindustry/world/blocks/environment/StaticTree.java b/core/src/mindustry/world/blocks/environment/StaticTree.java
index 35fa2ec5a9ec0a720be480069d9e492bf95ff473..a040e0d4b25155140f7aea174aefb996b07dc31d 100644
--- a/core/src/mindustry/world/blocks/environment/StaticTree.java
+++ b/core/src/mindustry/world/blocks/environment/StaticTree.java
@@ -17,42 +17,40 @@ public class StaticTree extends StaticWall{
 
     @Override
     public void drawBase(Tile tile){
-        if(!RenderExt.shouldDrawBuildingBase()){
-            if(RenderExt.shouldDrawOreLayer() && tile.overlay().wallOre){
-                tile.overlay().drawBase(tile);
-            }
-            return;
-        }
-
-        TextureRegion reg = variants > 0 ? variantRegions[Mathf.randomSeed(tile.pos(), 0, Math.max(0, variantRegions.length - 1))] : region;
-
-        TextureRegion r = Tmp.tr1;
-        r.set(reg);
-        int crop = (r.width - tilesize*4) / 2;
-        float ox = 0;
-        float oy = 0;
-
-        for(int i = 0; i < 4; i++){
-            if(tile.nearby(i) != null && tile.nearby(i).block() instanceof StaticWall){
-
-                if(i == 0){
-                    r.setWidth(r.width - crop);
-                    ox -= crop /2f;
-                }else if(i == 1){
-                    r.setY(r.getY() + crop);
-                    oy -= crop /2f;
-                }else if(i == 2){
-                    r.setX(r.getX() + crop);
-                    ox += crop /2f;
-                }else{
-                    r.setHeight(r.height - crop);
-                    oy += crop /2f;
+        boolean renderBlock = RenderExt.shouldDrawBuildingBase();
+        boolean renderOre = tile.overlay().wallOre && RenderExt.shouldDraw(tile.overlay());
+
+        if(renderBlock){
+            TextureRegion reg = variants > 0 ? variantRegions[Mathf.randomSeed(tile.pos(), 0, Math.max(0, variantRegions.length - 1))] : region;
+
+            TextureRegion r = Tmp.tr1;
+            r.set(reg);
+            int crop = (r.width - tilesize*4) / 2;
+            float ox = 0;
+            float oy = 0;
+
+            for(int i = 0; i < 4; i++){
+                if(tile.nearby(i) != null && tile.nearby(i).block() instanceof StaticWall){
+
+                    if(i == 0){
+                        r.setWidth(r.width - crop);
+                        ox -= crop /2f;
+                    }else if(i == 1){
+                        r.setY(r.getY() + crop);
+                        oy -= crop /2f;
+                    }else if(i == 2){
+                        r.setX(r.getX() + crop);
+                        ox += crop /2f;
+                    }else{
+                        r.setHeight(r.height - crop);
+                        oy += crop /2f;
+                    }
                 }
             }
+            Draw.rect(r, tile.drawx() + ox * Draw.scl, tile.drawy() + oy * Draw.scl);
         }
-        Draw.rect(r, tile.drawx() + ox * Draw.scl, tile.drawy() + oy * Draw.scl);
 
-        if(RenderExt.shouldDrawOreLayer() && tile.overlay().wallOre){
+        if(renderOre){
             tile.overlay().drawBase(tile);
         }
     }
