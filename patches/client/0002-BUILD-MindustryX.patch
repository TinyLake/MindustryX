Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

buildPlugins & Kotlin 1.9.20

patchArc改写成transform
way-zer <himc.wicp@gmail.com> on 2024/4/27 at 18:57
---
 build.gradle          | 6 ------
 core/build.gradle.kts | 4 ++++
 gradle.properties     | 2 +-
 server/build.gradle   | 2 ++
 settings.gradle       | 2 ++
 5 files changed, 9 insertions(+), 7 deletions(-)

diff --git a/build.gradle b/build.gradle
index 73431d8e757ff19a19b37f8a8d8e4446e98f6e5d..71619509254c843cdf8a0fe8d2c0d2271a2125af 100644
--- a/build.gradle
+++ b/build.gradle
@@ -205,12 +205,6 @@ project(":core"){
         destinationDir = layout.buildDirectory.dir("javadoc").get().asFile
     }
 
-    gradle.taskGraph.whenReady{
-        //these are completely unnecessary
-        tasks.kaptGenerateStubsKotlin.onlyIf{ false }
-        tasks.compileKotlin.onlyIf{ false }
-    }
-
     //comp** classes are only used for code generation
     jar{
         exclude("mindustry/entities/comp/**")
diff --git a/core/build.gradle.kts b/core/build.gradle.kts
index 712c4750377c079ec77bfea24bd889db58090b98..e1904111c3ca730e830b5c1bac3c1d5cacc6b3d1 100644
--- a/core/build.gradle.kts
+++ b/core/build.gradle.kts
@@ -1,10 +1,12 @@
 import org.gradle.jvm.tasks.Jar
 import org.jetbrains.kotlin.gradle.dsl.JvmTarget
+import org.jetbrains.kotlin.gradle.dsl.KotlinVersion
 import org.jetbrains.kotlin.gradle.tasks.KotlinCompile
 
 plugins {
     java
     kotlin("jvm")
+    id("mindustryX.buildExt")
 }
 sourceSets.main {
     java.setSrcDirs(listOf("src/", "../../src/", layout.buildDirectory.dir("/generated/sources/annotationProcessor/java/main")))
@@ -14,7 +16,9 @@ sourceSets.main {
 tasks {
     withType<KotlinCompile>().configureEach {
         compilerOptions {
+            languageVersion.set(KotlinVersion.KOTLIN_2_1)
             jvmTarget.set(JvmTarget.JVM_1_8)
+            freeCompilerArgs.add("-Xname-based-destructuring=complete")
         }
     }
 
diff --git a/gradle.properties b/gradle.properties
index bfe4f87a35f83db71c11aa2fc0c01ff1afed29b2..f683c8b4e216a6ed05ea5b3cefe6f812ea48a7a3 100644
--- a/gradle.properties
+++ b/gradle.properties
@@ -18,7 +18,7 @@ kapt.use.worker.api=true
 # Compilation avoidance (see https://kotlinlang.org/docs/kapt.html#compile-avoidance-for-kapt-since-1-3-20)
 kapt.include.compile.classpath=false
 # I don't need to use the kotlin stdlib, so remove it to prevent extra bloat & method count issues
-kotlin.stdlib.default.dependency=false
+#kotlin.stdlib.default.dependency=false
 #needed for android compilation
 android.useAndroidX=true
 org.gradle.caching=true
diff --git a/server/build.gradle b/server/build.gradle
index 7c1293746b6329d9904f237b94b1466869f9c47c..6085c24c1882c38982af03174166fa7c5fcc668e 100644
--- a/server/build.gradle
+++ b/server/build.gradle
@@ -49,6 +49,8 @@ tasks.register('dist', Jar){
     exclude("icons/icon_64.png")
     exclude("**hs_err**.log")
 
+    exclude("META-INF/kotlin*.kotlin_module")
+
     duplicatesStrategy = 'exclude'
 
     manifest{
diff --git a/settings.gradle b/settings.gradle
index e688b9a8ea87e6ac6e6899c0a2807fba38ff18be..1c8ab04d2d3469220b45117ec2684979a317a92f 100644
--- a/settings.gradle
+++ b/settings.gradle
@@ -9,6 +9,8 @@ if(JavaVersion.current().ordinal() < JavaVersion.VERSION_17.ordinal()){
     throw new Exception("!!! YOU MUST USE JAVA 17 OR ABOVE TO COMPILE AND RUN MINDUSTRY !!! Read the README. Your version: ${System.properties["java.version"]}")
 }
 
+includeBuild("../buildPlugins")
+
 include 'core', 'server', 'annotations', 'tools', 'tests'
 include 'desktop'
 //include 'ios'
