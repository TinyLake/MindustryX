+    public static String keyName(KeyBind.Axis axis){
+        if(axis.key == null){
+            assert axis.min != null && axis.max != null;
+            return axis.min.getName() + " [red]/[] " + axis.max.getName();
+        }
+        if(axis.modifiers == 0 || (axis.modifiers & KeyBind.modifierBit(axis.key)) != 0) return axis.key.getName();
+
+        StringBuilder builder = new StringBuilder();
+        if((axis.modifiers & KeyBind.modifierCtrl) != 0) builder.append("Ctrl+");
+        if((axis.modifiers & KeyBind.modifierAlt) != 0) builder.append("Alt+");
+        if((axis.modifiers & KeyBind.modifierMeta) != 0) builder.append("Win/Cmd+");
+        if((axis.modifiers & KeyBind.modifierShift) != 0) builder.append("Shift+");
+        builder.append(axis.key.getName());
+        return builder.toString();
+    }
+
     void rebind(KeyBind bind, KeyCode newKey){
         if(rebindKey == null) return;
         rebindDialog.hide();
