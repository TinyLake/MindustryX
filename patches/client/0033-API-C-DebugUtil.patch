diff --git a/core/src/mindustry/entities/EntityGroup.java b/core/src/mindustry/entities/EntityGroup.java
index ea8ef0cdb8a30b54bb304543ea92dc99da44acb6..100337b3b1e99a85788803e4396ddd571cea0b33 100644
--- a/core/src/mindustry/entities/EntityGroup.java
+++ b/core/src/mindustry/entities/EntityGroup.java
@@ -5,7 +5,9 @@ import arc.func.*;
 import arc.math.geom.*;
 import arc.struct.*;
 import arc.util.*;
+import mindustry.*;
 import mindustry.gen.*;
+import mindustryX.features.*;
 
 import java.util.*;
 
@@ -80,6 +82,17 @@ public class EntityGroup<T extends Entityc> implements Iterable<T>{
     }
 
     public void update(){
+        if(this == Groups.all && DebugUtil.traceUpdate){
+            for(index = 0; index < array.size; index++){
+                var e = array.items[index];
+                long start = System.nanoTime();
+                e.update();
+                long time = System.nanoTime() - start;
+                DebugUtil.logTrace("update", e, time);
+            }
+            DebugUtil.traceEnd();
+            return;
+        }
         for(index = 0; index < array.size; index++){
             array.items[index].update();
         }
