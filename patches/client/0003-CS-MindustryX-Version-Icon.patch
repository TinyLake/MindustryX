diff --git a/build.gradle b/build.gradle
index 71619509254c843cdf8a0fe8d2c0d2271a2125af..5f69c3a1b4f77494c3c4045664214ec6fe73fbe4 100644
--- a/build.gradle
+++ b/build.gradle
@@ -7,7 +7,11 @@ buildscript{
             def useLocalArc = localArc
             //skip to last submodule
             name = name.substring(name.lastIndexOf(':') + 1)
-            return "com.github.Anuken${useLocalArc ? "" : ".Arc"}:$name:$arcHash"
+            if(useLocalArc){
+                return "com.github.TinyLake.MindustryX:$name:$arcHash"
+            }else{
+                return "com.github.Anuken.Arc:$name:$arcHash"
+            }
         }
     }
 }
@@ -21,7 +25,7 @@ allprojects{
     apply plugin: 'maven-publish'
 
     version = project.hasProperty("packageVersion") ? project.getProperty("packageVersion") : 'release'
-    group = 'com.github.Anuken'
+    group = 'com.github.TinyLake.MindustryX'
 
     ext{
         versionNumber = '8'
