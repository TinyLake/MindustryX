diff --git a/core/src/mindustry/core/NetClient.java b/core/src/mindustry/core/NetClient.java
index dd4292c2ac8d14f1531ac310b31d54e12e3b17fe..e2b26d92a35e0cf936b7fdade158a93ebec5a951 100644
--- a/core/src/mindustry/core/NetClient.java
+++ b/core/src/mindustry/core/NetClient.java
@@ -29,6 +29,7 @@ import mindustry.net.*;
 import mindustry.net.Packets.*;
 import mindustry.world.*;
 import mindustry.world.modules.*;
+import mindustryX.*;
 
 import java.io.*;
 import java.util.*;
@@ -150,6 +151,7 @@ public class NetClient implements ApplicationListener{
             Log.info("Received world data: @", Strings.formatByteCount(data.stream.available()));
             NetworkIO.loadWorld(new InflaterInputStream(data.stream));
 
+            Time.run(60f, () -> Call.serverPacketReliable("MDTX", VarsX.version));
             finishConnecting();
         });
 
diff --git a/core/src/mindustry/core/Version.java b/core/src/mindustry/core/Version.java
index b2b59ddafcb5f022a51588caefd0b30121fcf7ac..24de76a2633e1f28b8d693cb91de8e57187e55a4 100644
--- a/core/src/mindustry/core/Version.java
+++ b/core/src/mindustry/core/Version.java
@@ -6,6 +6,7 @@ import arc.files.*;
 import arc.struct.*;
 import arc.util.*;
 import arc.util.io.*;
+import mindustryX.*;
 
 public class Version{
     /** Build type. 'official' for official releases; 'custom' or 'bleeding edge' are also used. */
@@ -82,6 +83,7 @@ public class Version{
         if(build == -1){
             return "custom build";
         }
-        return (type.equals("official") ? modifier : type) + " build " + build + (revision == 0 ? "" : "." + revision) + (commitHash.equals("unknown") ? "" : " (" + commitHash + ")");
+        return (type.equals("official") ? modifier : type) + " build " + build + (revision == 0 ? "" : "." + revision) + (commitHash.equals("unknown") ? "" : " (" + commitHash + ")") +
+        "\nMindustryX " + VarsX.version;
     }
 }
