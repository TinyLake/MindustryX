From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: way-zer <himc.wicp@gmail.com>
Date: Tue, 26 Mar 2024 19:22:00 +0800
Subject: [PATCH] HR: RenderExt

---
 core/src/mindustry/core/Renderer.java            | 3 ++-
 core/src/mindustry/graphics/BlockRenderer.java   | 3 ++-
 core/src/mindustry/graphics/OverlayRenderer.java | 3 ++-
 core/src/mindustry/input/InputHandler.java       | 5 +++++
 4 files changed, 11 insertions(+), 3 deletions(-)

diff --git a/core/src/mindustry/core/Renderer.java b/core/src/mindustry/core/Renderer.java
index 389684d7bb658688334d062df2cd3d9d7685ecf9..f25585b53208318e2b09c227e94915bf291b941e 100644
--- a/core/src/mindustry/core/Renderer.java
+++ b/core/src/mindustry/core/Renderer.java
@@ -20,6 +20,7 @@ import mindustry.graphics.g3d.*;
 import mindustry.maps.*;
 import mindustry.type.*;
 import mindustry.world.blocks.*;
+import mindustryX.features.*;
 
 import static arc.Core.*;
 import static mindustry.Vars.*;
@@ -416,7 +417,7 @@ public class Renderer implements ApplicationListener{
         Events.fire(Trigger.drawOver);
         blocks.drawBlocks();
 
-        Groups.draw.draw(Drawc::draw);
+        Groups.draw.draw(RenderExt::onGroupDraw);
 
         if(settings.getBool("drawhitboxes")){
             DebugCollisionRenderer.draw();
diff --git a/core/src/mindustry/graphics/BlockRenderer.java b/core/src/mindustry/graphics/BlockRenderer.java
index e645413bd928ebab24464ce5f6c1674ed27401da..a30f261320e2b4ea785b76848fc574e69d291b03 100644
--- a/core/src/mindustry/graphics/BlockRenderer.java
+++ b/core/src/mindustry/graphics/BlockRenderer.java
@@ -19,6 +19,7 @@ import mindustry.world.*;
 import mindustry.world.blocks.environment.*;
 import mindustry.world.blocks.environment.Floor.*;
 import mindustry.world.blocks.power.*;
+import mindustryX.features.*;
 
 import java.util.*;
 
@@ -724,7 +725,7 @@ public class BlockRenderer{
 
             if(block != Blocks.air && (visible || build.wasVisible)){
                 SpriteBatch.totalDrawCalls = 0;
-                block.drawBase(tile);
+                RenderExt.onBlockDraw(tile, block, build);
                 Draw.reset();
                 Draw.z(Layer.block);
 
diff --git a/core/src/mindustry/graphics/OverlayRenderer.java b/core/src/mindustry/graphics/OverlayRenderer.java
index 0795b6a38f43c33ae3fae877f1ae54dd79ea0949..9d1f4b1ebf944b4dac80b78954ff0719669fb1ed 100644
--- a/core/src/mindustry/graphics/OverlayRenderer.java
+++ b/core/src/mindustry/graphics/OverlayRenderer.java
@@ -17,6 +17,7 @@ import mindustry.gen.*;
 import mindustry.input.*;
 import mindustry.world.*;
 import mindustry.world.blocks.storage.CoreBlock.*;
+import mindustryX.features.*;
 
 import static mindustry.Vars.*;
 
@@ -217,7 +218,7 @@ public class OverlayRenderer{
             Building build = world.buildWorld(vec.x, vec.y);
 
             if(build != null && build.team == player.team()){
-                build.drawSelect();
+                RenderExt.onDrawSelect(build);
                 if(!build.enabled && build.block.drawDisabled){
                    build.drawDisabled();
                 }
diff --git a/core/src/mindustry/input/InputHandler.java b/core/src/mindustry/input/InputHandler.java
index a9d818c129b9b3e817d89c81c0ba0ac360d7dcdd..16da87606894814e40b8eb262f2d8fd4560250a9 100644
--- a/core/src/mindustry/input/InputHandler.java
+++ b/core/src/mindustry/input/InputHandler.java
@@ -360,6 +360,11 @@ public abstract class InputHandler implements InputProcessor, GestureListener{
                         ai.group = null;
                     }
 
+                    //remove when other player command
+                    if(!headless && player != Vars.player){
+                        if(control.input.selectedUnits.contains(unit)) RenderExt.onRtsRemoveUnit(player, unit);
+                    }
+
                     toAdd.add(unit);
                 }
             }
