diff --git a/core/src/mindustry/core/NetClient.java b/core/src/mindustry/core/NetClient.java
index 52088c330e65c9fa30d0bab87f9e020fb022f4b2..77388f59ed5beae422a72e92720ee05d6811f390 100644
